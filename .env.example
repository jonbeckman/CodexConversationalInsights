# Required Notion auth. The token is never printed by doctor or hook logs.
NOTION_TOKEN=secret_xxx

# Required Notion target.
CODEX_CONVERSATIONAL_INSIGHTS_NOTION_DATA_SOURCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Optional fallback parent for older Notion API/database behavior.
CODEX_CONVERSATIONAL_INSIGHTS_NOTION_DATABASE_ID=

# Per-install tags. Use Personal for a personal Codex and Consensys for work.
CODEX_CONVERSATIONAL_INSIGHTS_NOTION_TAGS=Personal

# Classifier and historical defaults.
CODEX_CONVERSATIONAL_INSIGHTS_MODEL=gpt-5.4-mini
CODEX_BACKFILL_PROMPT_MODEL=gpt-5.5

# Optional runtime tuning.
CODEX_CONVERSATIONAL_INSIGHTS_CODEX_PATH=/Applications/Codex.app/Contents/Resources/codex
CODEX_CONVERSATIONAL_INSIGHTS_NOTION_MIN_REQUEST_INTERVAL_MS=500
CODEX_CONVERSATIONAL_INSIGHTS_NOTION_MAX_RETRIES=8
